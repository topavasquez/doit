{
  "expo": {
    "name": "DoIt",
    "slug": "doit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "doit",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.doit.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.doit.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#6C47FF"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "DoIt needs access to your photos to attach proof to your check-ins.",
          "cameraPermission": "DoIt needs camera access to take check-in proof photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
